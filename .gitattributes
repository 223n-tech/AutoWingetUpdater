# Default: treat as text, normalize to LF in repo
* text=auto eol=lf

# Windows scripts must keep CRLF on checkout
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Task Scheduler XML is consumed by Windows tooling
*.xml          text eol=crlf
*.xml.template text eol=crlf

# Documentation / licenses
*.md    text eol=lf
LICENSE text eol=lf
